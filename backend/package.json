{
  "name": "jeevansetu-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "reseed": "node scripts/reseed.js",
    "reseed:yes": "node scripts/reseed.js --yes",
    "dev:reset": "node scripts/reseed.js --yes && nodemon src/server.js",
    "clean": "node scripts/cleanup.js --yes",
    "clean:dry": "node scripts/cleanup.js --dry-run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
